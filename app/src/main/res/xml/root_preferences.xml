<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Desktop Server">
        <EditTextPreference
            app:defaultValue="192.168.1.241:8080"
            app:key="desktop_server_url"
            app:singleLine="true"
            app:title="Server URL"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="MQTT Settings">
        <EditTextPreference
            app:defaultValue="tcp://broker.emqx.io:1883"
            app:key="mqtt_broker"
            app:singleLine="true"
            app:title="MQTT Broker"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:defaultValue="sunmi/print"
            app:key="mqtt_topic"
            app:singleLine="true"
            app:title="MQTT Topic"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Print Settings">
        <EditTextPreference
            app:defaultValue="3"
            app:key="default_lines_after"
            app:singleLine="true"
            app:title="Lines After Content"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Alert Settings">
        <SwitchPreferenceCompat
            app:defaultValue="false"
            app:key="alert_use_custom_size"
            app:title="Use Custom Size for Alert Text"
            app:summary="When off, the alert message always prints at a fixed large size regardless of Content Size." />
    </PreferenceCategory>

    <PreferenceCategory app:title="Guard Receipt">
        <EditTextPreference
            app:defaultValue="Guard"
            app:key="guard_company_name"
            app:singleLine="true"
            app:title="Company Name"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            app:defaultValue="50.00"
            app:key="guard_price"
            app:singleLine="true"
            app:title="Price per Entry"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

</PreferenceScreen>

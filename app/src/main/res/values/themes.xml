<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Light, not DayNight: the app's layouts/adapters hardcode colors tuned for a light
         background (e.g. EntranceReceiptsActivity's paid/unpaid row colors) and aren't dark-mode
         aware, so letting this follow the system's dark mode produces a broken half-dark,
         half-hardcoded-light mix on any device that actually has dark mode on. -->
    <style name="Theme.SunmiPrintTest" parent="Theme.Material3.Light.NoActionBar" />
</resources>
